{
  "name": "todo-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "set NODE_ENV=production && node server/server.js",
    "dev:server": "cd server && node server.js",
    "dev:client": "cd client && npx vite"
  },
  "engines": {
    "node": ">=18"
  }
}
